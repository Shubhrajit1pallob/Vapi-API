# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# ── Anthropic (Claude API) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Vapi ──────────────────────────────────────────────────────────────
VAPI_API_KEY=your-vapi-api-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_PHONE_NUMBER_ID=
VAPI_SERVER_URL=https://your-backend.example.com/vapi-webhook

# ── FastAPI backend (PostgreSQL fallback) ─────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vapi_db
API_KEY=your-default-api-key-change-in-production

# ── Admin UI ──────────────────────────────────────────────────────────
ADMIN_PORT=7860
